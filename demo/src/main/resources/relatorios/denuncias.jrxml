<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
        name="denuncias"
        pageWidth="595"
        pageHeight="842"
        columnWidth="555"
        leftMargin="20"
        rightMargin="20"
        topMargin="20"
        bottomMargin="20">

    <!-- CAMPOS -->
    <field name="id_denuncia" class="java.lang.Long"/>
    <field name="tipoIncendio" class="java.lang.String"/>
    <field name="gravidade" class="java.lang.String"/>
    <field name="latitude" class="java.math.BigDecimal"/>
    <field name="longitude" class="java.math.BigDecimal"/>
    <field name="descricao" class="java.lang.String"/>
    <field name="dataRegistro" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>

    <!-- TÍTULO -->
    <title>
        <band height="80">

            <rectangle>
                <reportElement x="0" y="0" width="555" height="60"/>
            </rectangle>

            <staticText>
                <reportElement x="10" y="5" width="535" height="45"/>
                <textElement textAlignment="Center">
                    <font size="34" isBold="true"/>
                </textElement>
                <text><![CDATA[DENUNCIE CHAMAS]]></text>
            </staticText>

            <staticText>
                <reportElement x="20" y="45" width="500" height="15"/>
                <textElement textAlignment="Center">
                    <font size="11"/>
                </textElement>
                <text><![CDATA[Relatório de Denúncias]]></text>
            </staticText>

        </band>
    </title>

    <!-- CABEÇALHO -->
    <pageHeader>
        <band height="35">

            <staticText>
                <reportElement x="0" y="10" width="130" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Gerado em:]]></text>
            </staticText>

            <textField>
                <reportElement x="100" y="10" width="200" height="20"/>
                <textFieldExpression><![CDATA[
                    new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm")
                    .format(new java.util.Date())
                ]]></textFieldExpression>
            </textField>

        </band>
    </pageHeader>

    <!-- DETALHES -->
    <detail>
        <band height="190">

            <!-- CARD -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="175"/>
            </rectangle>

            <!-- ID -->
            <textField>
                <reportElement x="15" y="15" width="120" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Denúncia #" + $F{id_denuncia}
                ]]></textFieldExpression>
            </textField>

            <!-- STATUS -->
            <textField>
                <reportElement x="380" y="15" width="150" height="20"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    "Status: " + $F{status}
                ]]></textFieldExpression>
            </textField>

            <!-- TIPO -->
            <staticText>
                <reportElement x="15" y="50" width="120" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Tipo Incêndio:]]></text>
            </staticText>

            <textField>
                <reportElement x="130" y="50" width="250" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{tipoIncendio}
                ]]></textFieldExpression>
            </textField>

            <!-- GRAVIDADE -->
            <staticText>
                <reportElement x="15" y="75" width="120" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Gravidade:]]></text>
            </staticText>

            <textField>
                <reportElement x="130" y="75" width="200" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{gravidade}
                ]]></textFieldExpression>
            </textField>

            <!-- COORDENADAS -->
            <staticText>
                <reportElement x="15" y="100" width="120" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Coordenadas:]]></text>
            </staticText>

            <textField>
                <reportElement x="130" y="100" width="380" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{latitude} + " , " + $F{longitude}
                ]]></textFieldExpression>
            </textField>

            <!-- DESCRIÇÃO -->
            <staticText>
                <reportElement x="15" y="125" width="120" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Descrição:]]></text>
            </staticText>

            <textField isStretchWithOverflow="true">
                <reportElement x="130" y="125" width="390" height="35"/>
                <textElement/>
                <textFieldExpression><![CDATA[
                    $F{descricao}
                ]]></textFieldExpression>
            </textField>

            <!-- DATA -->
            <staticText>
                <reportElement x="15" y="155" width="120" height="20"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Data Registro:]]></text>
            </staticText>

            <textField>
                <reportElement x="130" y="155" width="200" height="20"/>
                <textFieldExpression><![CDATA[
                    $F{dataRegistro}
                ]]></textFieldExpression>
            </textField>

        </band>
    </detail>

</jasperReport>